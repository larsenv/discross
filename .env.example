# discord bot token
TOKEN=your_discord_bot_token_here

# Sentry DSN for error logging (optional, leave blank to disable)
SENTRY_DSN=

# Set to 'true' to enable the Guild Members privileged intent.
# When enabled, Discross will automatically add/remove servers from the user's
# server list whenever they join or leave a guild (no manual OAuth sync needed).
# You must also enable the "Server Members Intent" in your bot's Discord Developer
# Portal settings before setting this to true.
GUILD_MEMBERS_INTENT=false

# Hot-reload static files in development (optional)
# Set to 'true' to enable automatic file watching for instant cache invalidation
# when HTML/CSS/JS/template files are modified. This provides faster hot-reloading
# during development. Without this flag, hot-reloading still works via file
# modification time checking, but without the instant notifications.
# Only affects development - no performance impact in production.
HOT_RELOAD=false