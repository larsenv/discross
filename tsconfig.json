{
    "compilerOptions": {
        "outDir": "dist",
        "module": "commonjs",
        "target": "es2022",
        "types": ["node"],
        "sourceMap": true,
        "declaration": false,
        "strict": false,
        "noImplicitAny": false,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowJs": true
    },
    "include": ["**/*.ts", "**/*.js"],
    "exclude": ["node_modules", "dist"]
}
